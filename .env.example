# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
DATABASE_URL="file:./dev.db"

# ═══════════════════════════════════════════════════════════════════════════
# MLS API CONNECTORS
# ═══════════════════════════════════════════════════════════════════════════

# Las Vegas (Clark County) - Trestle API (Corelogic)
# Get credentials from: https://trestle.corelogic.com/BKR/Tools/FeedOrganizer
TRESTLE_ENABLED=true
TRESTLE_CLIENT_ID=your_trestle_client_id
TRESTLE_CLIENT_SECRET=your_trestle_api_password

# St. George (Washington County) - Spark RESO OData v3
SPARK_WASHINGTON_ENABLED=true
SPARK_WASHINGTON_ACCESS_TOKEN=your_spark_washington_access_token
SPARK_WASHINGTON_FEED_ID=your_spark_washington_feed_id

# Cedar City (Iron County) - Spark RESO OData v3
SPARK_IRON_ENABLED=true
SPARK_IRON_ACCESS_TOKEN=your_spark_iron_access_token
SPARK_IRON_FEED_ID=your_spark_iron_feed_id

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Nodemailer)
# ═══════════════════════════════════════════════════════════════════════════

# Email Provider: gmail | outlook | sendgrid | custom
EMAIL_PROVIDER=gmail

# Gmail: get app password from https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# Report recipients
REPORT_FROM=noreply@southwestinvestment.local
REPORT_TO=your-email@gmail.com
REPORT_TO_CC=
REPORT_SUBJECT=Daily Property Analysis - Southwest Investment

# Scheduling (cron format)
REPORT_SCHEDULE=0 8 * * *
DELTA_CHECK_SCHEDULE=0 23 * * *
REPORT_TIMEZONE=America/Denver

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# Optional
ANTHROPIC_API_KEY=
