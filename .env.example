# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
DATABASE_URL="file:./dev.db"

# ═══════════════════════════════════════════════════════════════════════════
# MLS API CONNECTORS
# ═══════════════════════════════════════════════════════════════════════════

# MLXchange -- Las Vegas Market
MLXCHANGE_BASE_URL=https://your-mlxchange-endpoint.com/api
MLXCHANGE_API_KEY=your_mlxchange_api_key
MLXCHANGE_SAVED_SEARCH_ID=your_saved_search_id

# Flex Washington -- St. George Market
FLEX_WASHINGTON_BASE_URL=https://your-flex-washington-endpoint.com/api
FLEX_WASHINGTON_API_KEY=your_flex_washington_api_key
FLEX_WASHINGTON_SAVED_SEARCH_ID=your_saved_search_id

# Flex Iron -- Cedar City Market
FLEX_IRON_BASE_URL=https://your-flex-iron-endpoint.com/api
FLEX_IRON_API_KEY=your_flex_iron_api_key
FLEX_IRON_SAVED_SEARCH_ID=your_saved_search_id

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Nodemailer)
# ═══════════════════════════════════════════════════════════════════════════

# Email Provider: gmail | outlook | sendgrid | custom
EMAIL_PROVIDER=gmail

# Gmail Configuration (if using Gmail)
# Get app password from: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# Outlook Configuration (if using Outlook)
# EMAIL_USER=your-email@outlook.com
# EMAIL_PASSWORD=your-outlook-password

# SendGrid Configuration (if using SendGrid)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Custom SMTP Configuration (if using other provider)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-username
# SMTP_PASSWORD=your-password
# SMTP_TLS=true

# Report Email Settings
REPORT_FROM=noreply@southwestinvestment.local
REPORT_TO=your-email@gmail.com
REPORT_TO_CC=optional-cc@gmail.com
REPORT_SUBJECT=Daily Property Analysis - Southwest Investment

# Email Scheduling (cron format)
# Default: 8:00 AM daily ("0 8 * * *")
REPORT_SCHEDULE=0 8 * * *

# Nightly delta check schedule
# Default: 11:00 PM daily ("0 23 * * *")
DELTA_CHECK_SCHEDULE=0 23 * * *

# Timezone for scheduling (use TZ database name)
# Examples: America/Denver, America/Phoenix, UTC
REPORT_TIMEZONE=America/Denver

# ═══════════════════════════════════════════════════════════════════════════
# ANTHROPIC API (Claude 3.5 Sonnet)
# ═══════════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your_anthropic_api_key

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════
NODE_ENV=development
LOG_LEVEL=info
