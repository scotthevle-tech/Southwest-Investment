{
  "name": "southwest-investment-software",
  "version": "1.0.0",
  "description": "Automated property flip analysis and prioritization system for Southern Utah and Southern Nevada with web reporting",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:legacy": "node dist/index.js",
    "test:scoring": "ts-node src/tests/scoring-test-runner.ts",
    "test:email": "ts-node src/tests/email-test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "real-estate",
    "property-flip",
    "mls",
    "property-analysis",
    "automation",
    "web-reports"
  ],
  "author": "Scott",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@prisma/client": "^5.8.0",
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.10",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.8.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  }
}
